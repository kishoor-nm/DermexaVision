# ==========================================
# DermexaVision - .gitignore
# ==========================================

# ------------------------------------------
# Python
# ------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ------------------------------------------
# Virtual Environment
# ------------------------------------------
venv/
.venv/
env/

# ------------------------------------------
# Environment Variables
# ------------------------------------------
.env
.env.*

# ------------------------------------------
# IDE Settings
# ------------------------------------------
.vscode/
.idea/

# ------------------------------------------
# Jupyter Notebook
# ------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------
# OS Files
# ------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------
# Logs
# ------------------------------------------
*.log
logs/

# ------------------------------------------
# Build Files
# ------------------------------------------
build/
dist/
*.egg-info/

# ------------------------------------------
# TensorBoard
# ------------------------------------------
tensorboard_logs/

# ------------------------------------------
# Trained Models
# ------------------------------------------
models/*.keras
models/*.h5
models/*.hdf5

# Keep the folder
!models/.gitkeep

# ------------------------------------------
# Large Training Dataset
# ------------------------------------------
dataset/train/
dataset/val/

# ------------------------------------------
# Generated Outputs
# ------------------------------------------
outputs/

# Keep the folder
!outputs/.gitkeep

# ------------------------------------------
# Temporary Files
# ------------------------------------------
*.tmp
*.bak
*.swp